{
  "name": "lux-auction-multiplayer-fixed",
  "version": "1.0.0",
  "private": true,
  "description": "Realtime multiplayer land auction and policy simulation using Node.js, Socket.IO and React.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node --watch server.js\" \"vite --host 0.0.0.0 --config client/vite.config.js\"",
    "build": "vite build --config client/vite.config.js",
    "start": "node server.js"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.0",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^4.1.11",
    "vite": "^7.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
